import numpy as np
import matplotlib.pyplot as plt
from scipy.linalg import eig


# Parâmetros

N = 50             # número de átomos
rho = 0.5              # densidades em unidade de k = 1
Gamma = 1.0            # Gama = 1
k = 1.0                # definindo  k = 1
Delta = 0.0            # dessintonização

# comprimento do sistema e posições aleatórias
L = N / rho
np.random.seed(42)     #PAra ter consistência
positions = np.sort(np.random.uniform(0, L, N))

# matriz
M = np.zeros((N, N), dtype=complex)
for j in range(N):
    for m in range(N):
        if j == m:
            M[j, m] = 1j * Delta - Gamma / 2.0
        else:
            r_abs = np.abs(positions[j] - positions[m])
            M[j, m] = -Gamma/2.0 * np.exp(1j * k * r_abs)

# Autovalores e Autovetores
eigenvalues, eigenvectors = eig(M)


# usando o IPR
squared_amplitudes = np.abs(eigenvectors)**2
max_amp_indices = np.argmax(squared_amplitudes, axis=0)
max_amps = squared_amplitudes[max_amp_indices, range(N)]
# modo com maximo
Ind_modo_escolhido = np.argmax(max_amps)
psi = eigenvectors[:, Ind_modo_escolhido]
amp_sq = np.abs(psi)**2

## Registrar o CM do centro de massa do modo #
r_CM = np.sum(positions * amp_sq) / np.sum(amp_sq)

distancias = np.abs(positions - r_CM)

#Colocando um limitador#
lim = 1e-15
mask = amp_sq > lim
dist_fit = distancias[mask]
amp_sq_fit = amp_sq[mask]

# Log das amplitudes #
log_amp_sq_fit = np.log(amp_sq_fit)

# ajuste linear#
dec, intercept = np.polyfit(dist_fit, log_amp_sq_fit, 1)
xi = -1.0 / dec

#print(f"Modo escolhido: {Ind_modo_escolhido}")
#print(f"Comprimento de Localização ξ = {xi:.3f}")

plt.figure(figsize=(8, 5))
# plotar tdos em azul
plt.scatter(distancias, amp_sq, color='blue', s=30, label='Todos os Pontos')
# os primeiros em vermelho
plt.scatter(dist_fit, amp_sq_fit, color='red', s=30, label='Pontos escolhidos no ajuste')

d_line = np.linspace(0, np.max(dist_fit), 200)
fit_line = np.exp(intercept + dec * d_line)
plt.plot(d_line, fit_line, 'g-', linewidth=2, label=f'Fit: ξ = {xi:.2f}')

plt.yscale('log')
plt.xlabel(r'$|r_n - r_{CM}|$', fontsize=12)
plt.ylabel(r'$|\Psi_n|^2$', fontsize=12)
plt.title(f'Modo localizado {Ind_modo_escolhido}, N ={N}')
plt.legend()
plt.grid(True, alpha=0.3)
plt.tight_layout()
plt.show()



