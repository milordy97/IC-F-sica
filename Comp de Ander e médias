# Parametros
N_scan = 50               # numero de átomos
num_realizações = 20       # numero de configurações aleatórias por densidade
rho_values = np.linspace(0.2, 2.0, 30)   # densidades diferentes testadas


Gamma = 1.0
k = 1.0
Delta = 0.0

def compute_xi_for_positions(positions, Gamma, k, Delta):
    
    N = len(positions)
    M = np.zeros((N, N), dtype=complex)
    for j in range(N):
        for m in range(N):
            if j == m:
                M[j, m] = 1j * Delta - Gamma / 2.0
            else:
                r_abs = np.abs(positions[j] - positions[m])
                M[j, m] = -Gamma/2.0 * np.exp(1j * k * r_abs)
    
    eigvals, eigvecs = eig(M)
    
    # MModo mais localizado#
    sq_amps = np.abs(eigvecs)**2
    max_amp_indices = np.argmax(sq_amps, axis=0)
    max_amps = sq_amps[max_amp_indices, range(N)]
    idx_mode = np.argmax(max_amps)
    psi = eigvecs[:, idx_mode]
    amp_sq = np.abs(psi)**2
    
    #centro de massa#

    r_CM = np.sum(positions * amp_sq) / np.sum(amp_sq)
    distances = np.abs(positions - r_CM)
    
    # Ajuste exponencial
    threshold = 1e-15
    mask = amp_sq > threshold
    if np.sum(mask) < 3:
        return np.nan
    dist_fit = distances[mask]
    amp_sq_fit = amp_sq[mask]
    log_amp = np.log(amp_sq_fit)
    dec, _ = np.polyfit(dist_fit, log_amp, 1)
    xi = -1.0 / dec
    return xi if xi > 0 else np.nan

mean_xi = []
std_xi = []

for rho in rho_values:
    L = N_scan / rho
    xi_list = []
    for _ in range(num_realizações):
        # Diferentes sementes iniciais para cada realização#
        positions = np.sort(np.random.uniform(0, L, N_scan))
        xi = compute_xi_for_positions(positions, Gamma, k, Delta)
        if not np.isnan(xi):
            xi_list.append(xi)
    if len(xi_list) == 0:
        mean_xi.append(np.nan)
        std_xi.append(np.nan)
        print(f"ρ = {rho:.3f}: no valid fits")
    else:
        mean_xi.append(np.mean(xi_list))
        std_xi.append(np.std(xi_list))
        print(f"ρ = {rho:.3f}: \u03BE = {mean_xi[-1]:.2f} ± {std_xi[-1]:.2f}")




# Plot com ajuste de lei de potência (escala log-log)#


# Remove pontos inválidos (NaN ou xi <= 0)
valid_mask = ~np.isnan(mean_xi) & (np.array(mean_xi) > 0)
rho_valid = np.array(rho_values)[valid_mask]
xi_valid = np.array(mean_xi)[valid_mask]
std_valid = np.array(std_xi)[valid_mask]

if len(rho_valid) >= 2:
    # Ajuste linear em log10
    log_rho = np.log10(rho_valid)
    log_xi = np.log10(xi_valid)
    coeffs = np.polyfit(log_rho, log_xi, 1)  
    alpha = coeffs[0]
    C = 10 ** coeffs[1]
    
   

