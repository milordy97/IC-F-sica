plt.figure(figsize=(8, 6))
plt.errorbar(rho_values, mean_xi, yerr=std_xi, fmt='o-', capsize=1,
             color='blue', ecolor='gray', elinewidth=1, markeredgewidth=1,
             label='Dados simulados')

