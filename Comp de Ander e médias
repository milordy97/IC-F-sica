             label=f'Ajuste: $\\langle\\xi\\rangle = {C:.2f} \\rho^{{{alpha:.2f}}}$\n$R^2={r2:.3f}$')

plt.xlabel(r'$\rho$', fontsize=12)
plt.ylabel(r'$\langle \xi \rangle$', fontsize=12)
plt.xscale('log')
plt.yscale('log')
plt.grid(True, alpha=0.3)
plt.legend()
plt.tight_layout()
