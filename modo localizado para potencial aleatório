# print("\nAutovalores calculados (3 menores):")
for i, v in enumerate(vals):
    print(f"  E{i+1} = {v:.6f}")

# Calcular IPR para cada modo
print("\nInverse Participation Ratio (IPR):")
for i in range(nmodes):
    psi = vecs[:, i]
    rho = psi**2
    rho_norm = rho / np.sum(rho)  # Normalizar para soma = 1
    ipr = np.sum(rho_norm**2)
    print(f"  Estado {i+1}: IPR = {ipr:.4f} {'(localizado)' if ipr > 0.01 else '(estendido)'}")
